<!DOCTYPE html>
<html>
<head>
  <title>Students</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="nav">
  <a href="/">Home</a>
  <a href="/students">Students</a>
  <a href="/add">Add Student</a>
</div>

<h1>Student Records</h1>

<table>
  <tr>
    <th>ID</th>
    <th>Student ID</th>
    <th>Name</th>
    <th>Course</th>
    <th>Year</th>
    <th>Email</th>
    <th>Action</th>
  </tr>

  <% students.forEach(s => { %>
  <tr>
    <td><%= s.id %></td>
    <td><%= s.student_id %></td>
    <td><%= s.full_name %></td>
    <td><%= s.course %></td>
    <td><%= s.year_level %></td>
    <td><%= s.email %></td>
    <td>
      <a href="/edit/<%= s.id %>">Edit</a>
      <a href="/delete/<%= s.id %>">Delete</a>
    </td>
  </tr>
  <% }) %>

</table>

</body>
</html>